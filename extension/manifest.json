{
    "manifest_version": 3,
    "name": "Extension",
    "version": "1.0.0",
    "content_scripts": [
        {
            "matches": ["https://www.tiktok.com/*"],
            "js": ["content1.js"]
        },{
            "matches": ["https://www.youtube.com/*"],
            "js": ["content2.js"]
        },
        {
            "matches": ["https://www.facebook.com/*"],
            "js": ["content3.js"]
        },
        {
            "matches": ["https://www.instagram.com/*"],
            "js": ["content4.js"]
        }
    ]

}